{
  "ConnectionStrings": {
    "VitalDatabase": "Server=VITAL_SQL_SERVER;Database=VitalHIS;User Id=bital_readonly;Password=CHANGE_IN_PRODUCTION;TrustServerCertificate=True;Connection Timeout=30;",
    "VitalDatabaseReadOnly": "Server=VITAL_SQL_SERVER;Database=VitalHIS;User Id=bital_readonly;Password=CHANGE_IN_PRODUCTION;TrustServerCertificate=True;Connection Timeout=30;ApplicationIntent=ReadOnly;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bital-api-consultas-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ApiOptions": {
    "Name": "Bital API Consultas",
    "Version": "v1",
    "Description": "API Bridge read-only para consultas al HIS Vital",
    "ContactName": "Equipo Bital - Clínica del Río",
    "ContactEmail": "soporte.bital@clinicadelrio.com"
  },
  "HealthChecks": {
    "Enabled": true,
    "TimeoutSeconds": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "https://bital-dev.clinicadelrio.com"
    ]
  },
  "AllowedHosts": "*"
}
